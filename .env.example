# ==============================================================================
# LoL Manager — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# ==============================================================================

# ── Banco de dados (assíncrono — usado pelo SQLAlchemy/FastAPI) ─────────────
# Driver asyncpg para operações assíncronas na aplicação
DATABASE_URL=postgresql+asyncpg://lol_admin:lol_secret@localhost:5432/lol_manager_db

# Driver psycopg2 síncrono — usado exclusivamente pelo Alembic para migrações
SYNC_DATABASE_URL=postgresql+psycopg2://lol_admin:lol_secret@localhost:5432/lol_manager_db

# ── Redis ───────────────────────────────────────────────────────────────────
# URL de conexão com o Redis (cache + pub/sub)
REDIS_URL=redis://localhost:6379

# ── Segurança ───────────────────────────────────────────────────────────────
# Chave secreta para assinatura de tokens JWT (gere com: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Aplicação ───────────────────────────────────────────────────────────────
# Ativa modo debug (logs SQL, reload automático) — NUNCA use true em produção
DEBUG=false

# Ambiente de execução: development | staging | production
ENVIRONMENT=development
